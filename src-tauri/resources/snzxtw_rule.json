{
    "rule_name": "山南市职业技术学校",
    "rule_version": "0.1.0",
    "category": {
        "accept_pattern": "((西藏(.*?))?(山南|市)(.*?)(((第1)?((职业技术|职业|技术|职|业|技|术)(.*?)学[校院])|(职业技术|职业)(学?))|职[业校院]|1职))|(^(职[业校院]|1职)(.*?)(学[校院]))|^(职[业校院]|1职)",
        "accept_filter_pattern": "2",
        "reject_pattern": "拉萨市|日喀则市|林芝市|昌都市|那曲市|阿里地区"
    },
